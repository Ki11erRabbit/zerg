    comptime {
        x.use_variable();
        y.use_variable();
        put_instruction("f32.lt");
    }
}

pub inline fun (<=)(x: f32, y: f32): bool {
    comptime {
        x.use_variable();
        y.use_variable();
        put_instruction("f32.le");
    }
}

pub inline fun (>)(x: f32, y: f32): bool {
    comptime {
        x.use_variable();
